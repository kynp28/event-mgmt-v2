// =====================================================
// Event Sales Area Management System
// Prisma Schema — RBAC + Layered Architecture rebuild
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =====================================================
// RBAC CORE
// =====================================================

model Role {
  roleId      Int      @id @default(autoincrement()) @map("role_id")
  roleName    String   @unique @map("role_name") @db.VarChar(50)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  permissionId   Int      @id @default(autoincrement()) @map("permission_id")
  permissionName String   @unique @map("permission_name") @db.VarChar(100)
  description    String?  @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [roleId], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [permissionId], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     Int      @map("user_id")
  roleId     Int      @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [roleId], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// =====================================================
// USERS
// =====================================================

enum UserStatus {
  pending
  active
  suspended
  inactive
}

model User {
  userId       Int        @id @default(autoincrement()) @map("user_id")
  username     String     @db.VarChar(100)
  email        String     @unique @db.VarChar(150)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  userRoles          UserRole[]
  organizerRequests  OrganizerRequest[]
  organizedEvents    Event[]             @relation("EventOrganizer")
  bookings           Booking[]           @relation("VendorBookings")
  penalties          Penalty[]           @relation("VendorPenalties")
  auctionBids        Auction[]           @relation("CurrentBidder")
  reviewedRequests   OrganizerRequest[]  @relation("ReviewedBy")
  verifiedPayments   Payment[]           @relation("PaymentVerifier")
  createdBooths      Booth[]             @relation("BoothCreatedBy")
  updatedBooths      Booth[]             @relation("BoothUpdatedBy")
  waitlistEntries    Waitlist[]

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

// =====================================================
// ORGANIZER REQUEST (ขอสิทธิ์เป็นผู้จัดงาน — CI.02 6.1.1)
// =====================================================

enum RequestStatus {
  pending
  approved
  rejected
}

model OrganizerRequest {
  requestId   Int           @id @default(autoincrement()) @map("request_id")
  userId      Int           @map("user_id")
  status      RequestStatus @default(pending)
  feeAmount   Decimal       @map("fee_amount") @db.Decimal(10, 2)
  invoicePath String?       @map("invoice_path") @db.VarChar(255)
  reviewedBy  Int?          @map("reviewed_by")
  requestedAt DateTime      @default(now()) @map("requested_at")
  reviewedAt  DateTime?     @map("reviewed_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  user     User  @relation(fields: [userId], references: [userId])
  reviewer User? @relation("ReviewedBy", fields: [reviewedBy], references: [userId])

  @@index([userId])
  @@index([status])
  @@index([deletedAt])
  @@map("organizer_requests")
}

// =====================================================
// EVENTS
// =====================================================

enum EventStatus {
  draft
  open
  closed
  ended
  cancelled
}

model Event {
  eventId      Int         @id @default(autoincrement()) @map("event_id")
  organizerId  Int         @map("organizer_id")
  eventName    String      @map("event_name") @db.VarChar(200)
  location     String?     @db.Text
  imageUrl     String?     @map("image_url") @db.LongText
  startDate    DateTime    @map("start_date")
  endDate      DateTime    @map("end_date")
  eventStatus  EventStatus @default(draft) @map("event_status")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  organizer User       @relation("EventOrganizer", fields: [organizerId], references: [userId])
  booths    Booth[]
  zones     Zone[]
  landmarks Landmark[]
  bookings  Booking[]
  penalties Penalty[]
  auctions  Auction[]
  waitlists Waitlist[]

  @@index([organizerId])
  @@index([eventStatus])
  @@index([deletedAt])
  @@map("events")
}

// =====================================================
// ZONES & LANDMARKS (ผังบูธ)
// =====================================================

model Zone {
  zoneId    Int       @id @default(autoincrement()) @map("zone_id")
  eventId   Int       @map("event_id")
  zoneName  String    @map("zone_name") @db.VarChar(100)
  color     String    @default("#60a5fa") @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  event  Event   @relation(fields: [eventId], references: [eventId])
  booths Booth[]

  @@unique([eventId, zoneName])
  @@index([eventId])
  @@index([deletedAt])
  @@map("zones")
}

enum LandmarkType {
  entrance
  exit
  restroom
  rest_area
  stage
  info
  other
}

model Landmark {
  landmarkId Int          @id @default(autoincrement()) @map("landmark_id")
  eventId    Int          @map("event_id")
  label      String       @db.VarChar(100)
  type       LandmarkType @default(other)
  posX       Int          @default(0) @map("pos_x")
  posY       Int          @default(0) @map("pos_y")
  width      Int          @default(60)
  height     Int          @default(60)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  deletedAt  DateTime?    @map("deleted_at")

  event Event @relation(fields: [eventId], references: [eventId])

  @@index([eventId])
  @@index([deletedAt])
  @@map("landmarks")
}

// =====================================================
// BOOTHS
// =====================================================

enum BoothStatus {
  available
  booked
  auction
}

model Booth {
  boothId        Int         @id @default(autoincrement()) @map("booth_id")
  eventId        Int         @map("event_id")
  zoneId         Int?        @map("zone_id")
  boothNo        String      @map("booth_no") @db.VarChar(20)
  size           String?     @db.VarChar(50)
  price          Decimal     @db.Decimal(10, 2)
  isAuctionBooth Boolean     @default(false) @map("is_auction_booth")
  status         BoothStatus @default(available)
  posX           Int         @default(0) @map("pos_x")
  posY           Int         @default(0) @map("pos_y")
  width          Int         @default(80)
  height         Int         @default(60)
  createdBy      Int?        @map("created_by")
  updatedBy      Int?        @map("updated_by")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  event    Event     @relation(fields: [eventId], references: [eventId])
  zone     Zone?     @relation(fields: [zoneId], references: [zoneId])
  creator  User?     @relation("BoothCreatedBy", fields: [createdBy], references: [userId])
  updater  User?     @relation("BoothUpdatedBy", fields: [updatedBy], references: [userId])
  bookings Booking[]
  auctions Auction[]
  waitlists Waitlist[]

  @@unique([eventId, boothNo])
  @@index([eventId])
  @@index([zoneId])
  @@index([status])
  @@index([deletedAt])
  @@map("booths")
}

// =====================================================
// BOOKINGS
// =====================================================

enum BookingStatus {
  pending
  confirmed
  cancelled
}

model Booking {
  bookingId   Int           @id @default(autoincrement()) @map("booking_id")
  vendorId    Int           @map("vendor_id")
  boothId     Int           @map("booth_id")
  eventId     Int           @map("event_id")
  bookingDate DateTime      @default(now()) @map("booking_date")
  totalAmount Decimal       @map("total_amount") @db.Decimal(10, 2)
  status      BookingStatus @default(pending)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  vendor  User     @relation("VendorBookings", fields: [vendorId], references: [userId])
  booth   Booth    @relation(fields: [boothId], references: [boothId])
  event   Event    @relation(fields: [eventId], references: [eventId])
  payment Payment?
  auction Auction?

  @@index([vendorId])
  @@index([boothId])
  @@index([eventId])
  @@index([status])
  @@index([deletedAt])
  @@map("bookings")
}

// =====================================================
// PAYMENTS
// =====================================================

enum PaymentStatus {
  pending
  verified
  rejected
}

model Payment {
  paymentId   Int           @id @default(autoincrement()) @map("payment_id")
  bookingId   Int           @unique @map("booking_id")
  slipImage   String?       @map("slip_image") @db.LongText
  paymentDate DateTime      @default(now()) @map("payment_date")
  status      PaymentStatus @default(pending)
  verifiedBy  Int?          @map("verified_by")
  verifiedAt  DateTime?     @map("verified_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  booking  Booking @relation(fields: [bookingId], references: [bookingId])
  verifier User?   @relation("PaymentVerifier", fields: [verifiedBy], references: [userId])

  @@index([status])
  @@index([verifiedBy])
  @@map("payments")
}

// =====================================================
// AUCTIONS
// =====================================================

model Auction {
  auctionId       Int      @id @default(autoincrement()) @map("auction_id")
  boothId         Int      @map("booth_id")
  eventId         Int      @map("event_id")
  currentBidderId Int?     @map("current_bidder_id")
  currentPrice    Decimal  @default(0) @map("current_price") @db.Decimal(10, 2)
  endTime         DateTime @map("end_time")
  bookingId       Int?     @unique @map("booking_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  booth   Booth    @relation(fields: [boothId], references: [boothId])
  event   Event    @relation(fields: [eventId], references: [eventId])
  bidder  User?    @relation("CurrentBidder", fields: [currentBidderId], references: [userId])
  booking Booking? @relation(fields: [bookingId], references: [bookingId])

  @@index([boothId])
  @@index([eventId])
  @@index([endTime])
  @@map("auctions")
}

// =====================================================
// PENALTIES
// =====================================================

enum PenaltyStatus {
  unpaid
  paid
}

model Penalty {
  penaltyId  Int           @id @default(autoincrement()) @map("penalty_id")
  vendorId   Int           @map("vendor_id")
  eventId    Int           @map("event_id")
  reason     String        @db.Text
  fineAmount Decimal       @map("fine_amount") @db.Decimal(10, 2)
  status     PenaltyStatus @default(unpaid)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  vendor User  @relation("VendorPenalties", fields: [vendorId], references: [userId])
  event  Event @relation(fields: [eventId], references: [eventId])

  @@index([vendorId])
  @@index([eventId])
  @@index([status])
  @@map("penalties")
}

// =====================================================
// WAITLIST (คิวสำรอง)
// =====================================================

enum WaitlistStatus {
  waiting
  allocated
  cancelled
}

model Waitlist {
  waitlistId Int            @id @default(autoincrement()) @map("waitlist_id")
  vendorId   Int            @map("vendor_id")
  eventId    Int            @map("event_id")
  boothId    Int            @map("booth_id")
  status     WaitlistStatus @default(waiting)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  vendor User  @relation(fields: [vendorId], references: [userId])
  event  Event @relation(fields: [eventId], references: [eventId])
  booth  Booth @relation(fields: [boothId], references: [boothId])

  @@index([vendorId])
  @@index([eventId])
  @@index([boothId])
  @@index([status])
  @@map("waitlist")
}
